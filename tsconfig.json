{
  "compilerOptions": {
    "lib": ["dom", "ES2024"],
    "module": "ES2022",
    "target": "ES2024",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "noEmit": true,
    "moduleResolution": "bundler"
  },
  "exclude": ["node_modules"]
}
